# ----------------- 服务配置 -----------------
# 端口
PORT=3000

# ----------------- 单机多进程集群模式配置 -----------------
# 是否启用集群模式，默认关闭
# CLUSTER_ENABLED=true
# worker 进程数量，默认 CPU 核心数，至少 1
# CLUSTER_WORKERS=4
# worker 崩溃后重启延迟（毫秒），默认 1000
# CLUSTER_RESTART_DELAY=1000
# 时间窗口内允许的最大重启次数, 默认 5，超过则熔断
# CLUSTER_MAX_RESTARTS=5
# 重启计数的统计时间窗口（毫秒）, 默认 60000
# CLUSTER_RESTART_WINDOW=60000

# ----------------- 数据库配置 -----------------
# 类型
DATABASE_TYPE="mysql"
# IP
DATABASE_HOST="127.0.0.1"
# 端口
DATABASE_PORT="3306"
# 库名
DATABASE_NAME="test_db"
# 用户
DATABASE_USER="test_db"
# 密码
DATABASE_PASSWORD="123456"
# 地址
DATABASE_URL="mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}"
# 影子数据库
DATABASE_SHADOW_NAME="test_db_shadow"
DATABASE_SHADOW_URL="mysql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_SHADOW_NAME}"

# ----------------- Redis 配置 -----------------
# REDIS_URL=""