{
  "name": "app-elysia",
  "version": "1.0.50",
  "type": "module",
  "scripts": {
    "menu": "bun run ./support/script/menu.ts",
    "dev-parallel": "bun --parallel run script_generate dev",
    "dev": "bun run --watch ./app/cluster.ts",
    "fix": "bunx --bun @biomejs/biome check --write .",
    "generate": "bun --parallel run script_generate prisma_generate",
    "script_generate": "bun ./support/script/index.ts",
    "prisma_generate": "bun --bun run prisma generate"
  },
  "dependencies": {
    "@elysiajs/eden": "1.4.9",
    "@elysiajs/openapi": "1.4.14",
    "@elysiajs/static": "1.4.7",
    "@prisma/adapter-mariadb": "7.6.0",
    "@prisma/client": "7.6.0",
    "elysia": "1.4.28",
    "prismabox": "1.1.26"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "bun-types": "1.3.11",
    "prisma": "7.6.0"
  },
  "module": "./index.js"
}
